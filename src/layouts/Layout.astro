---
import '../styles/globals.css';
interface Props {
	title: string;
	description?: string;
    image?: string;
}

const { 
    title, 
    description = "We are VALSOFT, a software development company that creates cutting-edge applications for your business. Together, we can make your dream a reality.",
    image = "/hero-bg-01.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/valsoft-favicon-light.png" media="(prefers-color-scheme: light)" />
        <link rel="icon" href="/valsoft-favicon-dark.png" media="(prefers-color-scheme: dark)" />
		<meta name="generator" content={Astro.generator} />

        <link rel="canonical" href={canonicalURL} />
		<title>{title}</title>

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital@1&display=swap" rel="stylesheet">
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.8/dist/katex.min.css"
            integrity="sha384-GvrOXuhMATgEsSwCs4sm5u0Q+f8mxOWad8wJJUI6WvsK7wHBnr9z1dnVfChVzhSW"
            crossorigin="anonymous"
        />
        <meta name="google-site-verification" content="b_cKgDou28ekCRjHrahSb2PCFbbxcBlQU7oltmphpK0" />
        <meta name="description" content={description} />
        <meta name="keywords" content="software development agency, software developer, web developer, JavaScript, React, Node.js, full stack, e-commerce, web application" />
        <meta name="author" content="Matias Valtolina" />
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	:root {
		--accent: 136, 58, 234;
		--accent-light: 224, 204, 250;
		--accent-dark: 49, 10, 101;
		--accent-gradient: linear-gradient(
			45deg,
			rgb(var(--accent)),
			rgb(var(--accent-light)) 30%,
			white 60%
		);
	}
	html {
		font-family: system-ui, sans-serif;
		background: #ffffff;
		background-size: 224px;
        scroll-behavior: smooth;
	}
	code {
		font-family:
			Menlo,
			Monaco,
			Lucida Console,
			Liberation Mono,
			DejaVu Sans Mono,
			Bitstream Vera Sans Mono,
			Courier New,
			monospace;
	}
	.katex-html {                                   
        display: none;                                
    } 
	.katex-mathml {                                   
        font-size: 18pt;                                
    } 
</style>
